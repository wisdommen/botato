{
	"name": "AutoBattlerEnhanced",
	"namespace": "Pasha",
	"version_number": "2.1.4",
	"description": "Do you want to work for potatoes or do you want potatoes to work for you? Enhanced with adaptive weights and extended force categories.",
	"website_url": "",
	"dependencies": [],
	"extra": {
		"godot": {
			"incompatibilities": [],
			"authors": ["Pasha"],
			"compatible_mod_loader_version": ["6.0.0"],
			"compatible_game_version": ["0.8.0.3"],

			"config_schema": {
				"title": "Autobattler Settings",
				"description": "Config for Botato",
				"type" : "object",
				"properties" : {
					"ENABLE_AUTOBATTLER" : {
						"type": "boolean",
						"default": false,
						"tooltip": "ENABLE_AUTOBATTLER_TOOLTIP"
					},
					"ENABLE_AI_VISUALS" : {
						"type": "boolean",
						"default": false,
						"tooltip": "ENABLE_AI_VISUALS_TOOLTIP"
					},
					"ENABLE_AI_MARKER" : {
						"type": "boolean",
						"default": true,
						"tooltip": "ENABLE_AI_MARKER_TOOLTIP"
					},
					"ENABLE_SMOOTHING" : {
						"type": "boolean",
						"default": true,
						"tooltip": "ENABLE_SMOOTHING_TOOLTIP"
					},
					"SMOOTHING_SPEED" : {
						"type": "number",
						"minimum" : 0,
						"maximum" : 10.0,
						"default" : 1.0,
						"tooltip": "SMOOTHING_SPEED_TOOLTIP"
					},
					"ITEM_WEIGHT" : {
						"type": "number",
						"minimum": 0.0,
						"maximum": 10.0,
						"default": 0.25,
						"tooltip": "ITEM_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"PROJECTILE_WEIGHT": {
						"type": "number",
						"minimum": 0.0,
						"maximum": 20.0,
						"default": 4.0,
						"tooltip": "PROJECTILE_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"TREE_WEIGHT": {
						"type": "number",
						"minimum": 0.0,
						"maximum": 20.0,
						"default": 4.0,
						"tooltip": "TREE_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"BOSS_WEIGHT": {
						"type": "number",
						"minimum": 0.0,
						"maximum": 30.0,
						"default": 9.0,
						"tooltip": "BOSS_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"BUMPER_WEIGHT": {
						"type": "number",
						"minimum": 0.0,
						"maximum": 10.0,
						"default": 2.0,
						"tooltip": "BUMPER_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"EGG_WEIGHT": {
						"type": "number",
						"minimum": 0.0,
						"maximum": 50.0,
						"default": 25.0,
						"tooltip": "EGG_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"BUMPER_DISTANCE": {
						"type": "number",
						"minimum": 1.0,
						"maximum": 1000.0,
						"default": 300.0,
						"tooltip": "BUMPER_DISTANCE_TOOLTIP",
						"format": "%1.0f"
					},
					"CONSUMABLE_WEIGHT": {
						"type": "number",
						"minimum": 0.0,
						"maximum": 5.0,
						"default": 1.0,
						"tooltip": "CONSUMABLE_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"CRATE_WEIGHT": {
						"type": "number",
						"minimum": 0.0,
						"maximum": 10.0,
						"default": 0.5,
						"tooltip": "CRATE_WEIGHT_TOOLTIP",
						"format": "%.2f X"
					},
					"ENABLE_DEBUG_LOG": {
						"type": "boolean",
						"default": false,
						"tooltip": "ENABLE_DEBUG_LOG_TOOLTIP"
					}
				}
			}
		}
	}
}
